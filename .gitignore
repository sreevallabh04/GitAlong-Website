# =========================================================
# GitAlong - Monorepo .gitignore (Vite + React + Python)
# =========================================================

# ---------- Environment / secrets ----------
.env
.env.*
!.env.example
!.env.*.example

*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*.p8

secrets.*
credentials.*
service-account.*
firebase-service-account.*
google-service-account.*
aws-credentials.*
azure-credentials.*
gcp-credentials.*

# ---------- Node / frontend ----------
node_modules/

dist/
dist-ssr/
build/
out/

coverage/
*.lcov
.nyc_output/

.vite/
.cache/
.parcel-cache/

.npm/
.pnpm-store/

.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

*.tsbuildinfo
.eslintcache

# ---------- Python / backend ----------
__pycache__/
*.py[cod]
*$py.class

.python-version

.venv/
venv/
env/
ENV/

.mypy_cache/
.pytest_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/

.coverage
.coverage.*
htmlcov/

pip-wheel-metadata/
*.egg-info/
.eggs/

# ---------- Logs / runtime ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

pids/
*.pid
*.seed
*.pid.lock

# ---------- Cloud / deployment ----------
.vercel/
.firebase/
firebase-debug.log
firebase-debug.*.log

# ---------- OS / editor ----------
.DS_Store
Thumbs.db
Desktop.ini

.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*.swo
*~

# ---------- Misc ----------
tmp/
temp/

# Keep deployment config files tracked
!render.yaml
!vercel.json
